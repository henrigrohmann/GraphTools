{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start FastAPI (uvicorn)",
      "type": "shell",
      "command": "uvicorn",
      "args": [
        "server:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8005"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Frontend Static Server",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "http.server",
        "8002"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Run API Smoke Test",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/smoke_api.py",
        "--base-url",
        "http://127.0.0.1:8005",
        "--log-dir",
        "logs/smoke"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
